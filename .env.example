# CrewCast Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase — get from https://app.supabase.com > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Web URL — used to build shareable invite links on native apps
# On web this is detected automatically. On native, set this to your deployed web URL.
# Falls back to crewcast:// deep link scheme if not set.
# EXPO_PUBLIC_WEB_URL=https://app.crewcast.io

# Stripe (future billing integration)
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...  (server-side only, never expose to client)
